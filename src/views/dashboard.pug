extends layout

block content
  #dashboard-page.min-h-screen.bg-gray-100
    .container.mx-auto.px-4.py-8
      .flex.items-center.justify-between.mb-8
        h1#welcome-message.text-4xl.font-bold.text-gray-800 Welcome!
        button#import-csv-btn.bg-blue-600.text-white.px-4.py-2.rounded-lg.shadow(
          class="hover:bg-blue-700"
        ) Import CSV
      input#csv-file-input.hidden(type="file" accept=".csv")

      #summary-bar.flex.flex-row.flex-wrap.gap-4.mb-8
        .bg-white.flex-1.rounded-lg.shadow.p-6
          p.text-sm.text-gray-500.font-medium Total Spend
          p#total-spend.text-2xl.font-bold.text-gray-800 —
        .bg-white.flex-1.rounded-lg.shadow.p-6
          p.text-sm.text-gray-500.font-medium Total Revenue
          p#total-revenue.text-2xl.font-bold.text-gray-800 —
        .bg-white.flex-1.rounded-lg.shadow.p-6
          p.text-sm.text-gray-500.font-medium Overall ROAS
          p#overall-roas.text-2xl.font-bold.text-gray-800 —

      .flex.items-center.gap-3.mb-4
        label.text-sm.font-semibold.text-gray-700(for="min-roas-filter") Minimum ROAS:
        input#min-roas-filter(
          type="number"
          min="0"
          step="0.1"
          placeholder="e.g. 2.0"
          class="w-32 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        )

      #campaigns-section.mt-8
        h2.text-2xl.font-bold.text-gray-800.mb-4 Your Campaigns
        #campaigns-loading.text-gray-600 Loading campaigns...
        #campaigns-error.hidden.text-red-600 Failed to load campaigns.
        #campaigns-empty.hidden.text-gray-500 No campaigns found.
        .overflow-x-auto
          table#campaigns-table.hidden.w-full.bg-white.rounded-lg.shadow
            thead.bg-gray-200
              tr
                th.px-4.py-3.text-left.text-sm.font-semibold.text-gray-700 Campaign Name
                th.px-4.py-3.text-left.text-sm.font-semibold.text-gray-700 Platform
                th.px-4.py-3.text-right.text-sm.font-semibold.text-gray-700 Spend
                th.px-4.py-3.text-right.text-sm.font-semibold.text-gray-700 Revenue
                th.px-4.py-3.text-right.text-sm.font-semibold.text-gray-700 Conversions
                th.px-4.py-3.text-right.text-sm.font-semibold.text-gray-700 ROAS
                th.px-4.py-3.text-right.text-sm.font-semibold.text-gray-700 CPA
            tbody#campaigns-table-body

      #modal.hidden.fixed.inset-0.bg-gray-900.bg-opacity-50.flex.items-center.justify-center
        .bg-white.p-6.rounded-lg.shadow-lg.max-w-md.w-full
          h2.text-xl.font-bold.text-red-600.mb-4 Import Error
          p#modal-message.text-gray-700.mb-6
          button#modal-close.bg-red-600.text-white.px-4.py-2.rounded(
            class="hover:bg-red-700"
          ) Close
